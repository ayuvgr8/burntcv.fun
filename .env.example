# ── Core ─────────────────────────────────────────────────────────────
# Platform Claude API key — powers free & Pro roasts (server-side only).
# Without this, the app steers users to bring their own key (BYOK).
# Used directly UNLESS AI_GATEWAY_API_KEY is set (then it's the fallback path).
ANTHROPIC_API_KEY=sk-ant-api03-...

# Vercel AI Gateway key (optional but recommended). When set, platform roast
# calls route through the gateway's Anthropic-compatible endpoint for per-request
# cost/latency/spend dashboards + provider failover, at zero token markup.
# Get it: Vercel dashboard → project → AI Gateway → API keys. Then set a budget.
# AI_GATEWAY_API_KEY=vck_...
# Gateway model slug is provider-prefixed with dots. Default: anthropic/claude-sonnet-4.6
# GATEWAY_ROAST_MODEL=anthropic/claude-sonnet-4.6

# Public site URL — used for OG/Twitter share images, sitemap, robots.
# Set to your production domain.
NEXT_PUBLIC_SITE_URL=https://burntcv.app

# ── Optional tuning ──────────────────────────────────────────────────
# Override the roast model. Default: claude-sonnet-4-6
# ROAST_MODEL=claude-sonnet-4-6

# Free roasts per IP per day (rate limit). Default 5.
# FREE_ROASTS_PER_DAY=5

# Global daily spend cap (USD) on the platform Claude key — the catastrophe
# backstop above per-IP limits: caps TOTAL platform spend per UTC day so an
# IP-rotating abuser or a viral spike can't run up an unbounded Anthropic bill.
# When the day's budget is spent, free/single/top-up roasts steer to BYOK until
# the window rolls over; verified Pass holders are never blocked. Best-effort
# without Upstash Redis (durable + distributed with it). Default 10. Set 0 to
# disable the cap entirely.
# PLATFORM_DAILY_BUDGET_USD=10

# Upstream request timeout in ms. Default 45000.
# ROAST_TIMEOUT_MS=45000

# ── Payments (Razorpay) — go live with ₹7 / ₹5 / ₹49 / ₹199 charges ──
# Without these, the pay-to-roast flow runs in SIMULATED mode (unlocks
# instantly, no real charge). Add both to charge for real.
# NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxx   # client — enables real checkout
# RAZORPAY_KEY_SECRET=xxxxxxxx                     # server — signs & verifies orders
# Webhook (reliability net): set the SAME secret in Razorpay → Webhooks, and
# point the webhook at https://<domain>/api/payment/webhook (event: payment.captured).
# RAZORPAY_WEBHOOK_SECRET=whsec_xxxxxxxx

# ── Payments (Creem) — international checkout, Merchant of Record ─────
# India is served by Razorpay (above); everyone else checks out via Creem,
# which acts as Merchant of Record (handles global cards + sales tax/VAT).
# THREE one-time products are sold internationally (all above the $4.99 friction
# floor — no sub-$1 micro-charges, fees eat them):
#   • $9.99 6-Month Pass   (400 roasts / 6 months + 4 included Glow-Ups)
#   • $4.99 Glow-Up        (a non-Pass user's one-off rewrite)
#   • $3.99 Glow-Up top-up (a Pass holder's 5th+ Glow-Up, cheaper loyalty price)
# Which product a checkout paid for is verified server-side by its product id, so
# a $4.99/$3.99 Glow-Up can't be redeemed as a $9.99 Pass. Without these, the Creem
# cards run in SIMULATED mode. The key prefix routes the environment: creem_test_…
# → test API, creem_live_… → live API. Create all three products + get the
# key/secret in the Creem dashboard.
# CREEM_API_KEY=creem_live_xxxxxxxx              # server — creates & verifies checkouts
# CREEM_PRODUCT_ID=prod_xxxxxxxx                 # the one-time $9.99 6-Month Pass product
# CREEM_GLOWUP_PRODUCT_ID=prod_xxxxxxxx          # the one-time $4.99 Glow-Up product
# CREEM_GLOWUP_TOPUP_PRODUCT_ID=prod_xxxxxxxx    # the one-time $3.99 Glow-Up top-up product
# Webhook (reliability net): set this to the webhook signing secret and point
# Creem → Webhooks at https://<domain>/api/creem/webhook (event: checkout.completed).
# CREEM_WEBHOOK_SECRET=whsec_xxxxxxxx

# ── Entitlements + durable rate limiting (Upstash Redis) ─────────────
# REQUIRED for the 6-Month Pass to survive browser-clear / device-switch
# (the Pass is stored here, keyed by restore code + paid email). Also makes
# the per-IP rate limit durable + distributed. Without it, both fall back to
# a best-effort in-process store. Create a free DB at upstash.com.
# UPSTASH_REDIS_REST_URL=https://....upstash.io
# UPSTASH_REDIS_REST_TOKEN=...
# Secret used to sign Pass tokens. Defaults to RAZORPAY_KEY_SECRET if unset.
# ENTITLEMENT_SECRET=a-long-random-string
